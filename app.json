{
  "expo": {
    "name": "DeepNode Vision",
    "slug": "deepnode-vision",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "package": "com.deepnodeindustries.vision",
      "adaptiveIcon": {
        "backgroundColor": "#020817"
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#020817",
          "resizeMode": "contain",
          "enableFullScreenImage_legacy": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DeepNode Vision necesita acceso a tus fotos para analizar documentos.",
          "cameraPermission": "DeepNode Vision necesita acceso a tu cámara para capturar documentos."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "scheme": "deepnode",
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "extra": {
      "router": { "origin": false }
    }
  }
}
